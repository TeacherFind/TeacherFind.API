<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeacherFind.Mobile.Features.Teachers.Views.TeacherListPage"
             Title="Eğitmenleri Keşfedin"
             BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20,15" BackgroundColor="White">
            <Border Grid.Column="0" StrokeShape="RoundRectangle 20" Stroke="Transparent" BackgroundColor="#E8EEFC" Padding="15,8" HorizontalOptions="Start">
                <Label Text="{Binding TotalCountText}" TextColor="#0A194F" FontAttributes="Bold" FontSize="12"/>
            </Border>

            <Button Grid.Column="1" Text="🎛 Filtrele &amp; Sırala" 
                    BackgroundColor="Transparent" TextColor="#0A194F" FontAttributes="Bold"
                    Clicked="OnFilterButtonClicked"/>
        </Grid>

        <Grid Grid.Row="1" Padding="20">
            <CollectionView ItemsSource="{Binding Teachers}" VerticalScrollBarVisibility="Never">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 20" Stroke="Transparent" BackgroundColor="White" Margin="0,0,0,20" Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,5" Radius="15" Opacity="0.05" />
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="15">

                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Grid Grid.Column="0" WidthRequest="60" HeightRequest="60">
                                        <Border StrokeShape="RoundRectangle 30" Stroke="Transparent" WidthRequest="60" HeightRequest="60">
                                            <Image Source="{Binding AvatarUrl}" Aspect="AspectFill"/>
                                        </Border>
                                        <Border IsVisible="{Binding IsOnline}" BackgroundColor="#2ECC71" Stroke="White" StrokeThickness="2" StrokeShape="RoundRectangle 7.5" WidthRequest="15" HeightRequest="15" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,5,5"/>
                                    </Grid>

                                    <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="#212121"/>
                                        <HorizontalStackLayout Spacing="5" Margin="0,2,0,0">
                                            <Label Text="⭐" FontSize="12"/>
                                            <Label Text="{Binding Rating}" TextColor="#FFA000" FontAttributes="Bold" FontSize="12"/>
                                            <Label Text="{Binding ReviewCount}" TextColor="Gray" FontSize="11"/>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding Price}" TextColor="#2962FF" FontAttributes="Bold" FontSize="14" Margin="0,5,0,0"/>
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2" Text="♡" FontSize="24" TextColor="Gray" VerticalOptions="Start"/>
                                </Grid>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="14" TextColor="#212121"/>
                                    <Label Text="{Binding Description}" FontSize="12" TextColor="Gray" LineBreakMode="TailTruncation" MaxLines="2"/>
                                </VerticalStackLayout>

                                <CollectionView ItemsSource="{Binding Badges}" ItemsLayout="HorizontalList" HeightRequest="30">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" BackgroundColor="#F9FAFC" Padding="10,5" Margin="0,0,8,0">
                                                <Label Text="{Binding Text}" FontSize="10" TextColor="#555555" VerticalOptions="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,10,0,0">
                                    <Button Grid.Column="0" Text="Profili İncele" BackgroundColor="#2962FF" TextColor="White" CornerRadius="10" HeightRequest="45" FontSize="13" FontAttributes="Bold"/>
                                    <Button Grid.Column="1" Text="Mesaj Gönder" BackgroundColor="Transparent" TextColor="#212121" BorderColor="#E0E0E0" BorderWidth="1" CornerRadius="10" HeightRequest="45" FontSize="13" FontAttributes="Bold"/>
                                </Grid>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

    </Grid>
</ContentPage>