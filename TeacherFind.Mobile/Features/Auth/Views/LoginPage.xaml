<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeacherFind.Mobile.Features.Auth.Views.LoginPage"
             Title="Giriş Yap"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundColorLight}, Dark={StaticResource PageBackgroundColorDark}}">

    <ScrollView>
        <Grid Padding="20" VerticalOptions="Center">
            
            <!-- Form Container -->
            <Border Stroke="{AppThemeBinding Light={StaticResource BorderLightColor}, Dark=#334155}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#E6FFFFFF, Dark=#1e293b}"
                    Padding="30"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="480">
                
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="20">
                    
                    <!-- Header -->
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center" Margin="0,0,0,10">
                        <Label Text="Hoş Geldiniz" 
                               FontSize="24" 
                               FontAttributes="Bold" 
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryColor}, Dark={StaticResource TextWhiteColor}}"
                               HorizontalOptions="Center" />
                        <Label Text="Devam etmek için giriş yapın" 
                               FontSize="14" 
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#94a3b8}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Email Input -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="E-posta" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#cbd5e1}"/>
                        
                        <Border Stroke="{Binding EmailBorderColor}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource BgLightColor}, Dark=#0f172a}"
                                HeightRequest="52"
                                Padding="16,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*">
                                <!-- Temporary placeholder for SVG icon -->
                                <Label Text="✉" 
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#94a3b8}"
                                       VerticalOptions="Center"
                                       Margin="0,0,8,0"
                                       FontSize="18" />
                                <Entry Grid.Column="1"
                                       Text="{Binding Email}"
                                       Placeholder="E-posta adresinizi girin"
                                       Keyboard="Email"
                                       Focused="OnEntryFocused"
                                       Unfocused="OnEntryUnfocused"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryColor}, Dark={StaticResource TextWhiteColor}}"
                                       BackgroundColor="Transparent"
                                       ClearButtonVisibility="WhileEditing"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password Input -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Şifre" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#cbd5e1}"/>
                        
                        <Border Stroke="{Binding PasswordBorderColor}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource BgLightColor}, Dark=#0f172a}"
                                HeightRequest="52"
                                Padding="16,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Temporary placeholder for SVG icon -->
                                <Label Text="🔒" 
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#94a3b8}"
                                       VerticalOptions="Center"
                                       Margin="0,0,8,0"
                                       FontSize="18" />
                                
                                <Entry Grid.Column="1"
                                       Text="{Binding Password}"
                                       Placeholder="Şifrenizi girin"
                                       IsPassword="{Binding IsPasswordHidden}"
                                       Focused="OnEntryFocused"
                                       Unfocused="OnEntryUnfocused"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryColor}, Dark={StaticResource TextWhiteColor}}"
                                       BackgroundColor="Transparent"/>
                                
                                <ImageButton Grid.Column="2"
                                             Clicked="OnTogglePasswordClicked"
                                             BackgroundColor="Transparent"
                                             WidthRequest="24"
                                             HeightRequest="24"
                                             VerticalOptions="Center">
                                    <ImageButton.Source>
                                        <FontImageSource FontFamily="OpenSansRegular"
                                                         Glyph="{Binding PasswordIconGlyph}"
                                                         Color="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#94a3b8}"
                                                         Size="18" />
                                    </ImageButton.Source>
                                </ImageButton>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Remember Me & Forgot Password -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,5">
                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <CheckBox IsChecked="{Binding RememberMe}" Color="{StaticResource PrimaryColor}" />
                            <Label Text="Beni hatırla" 
                                   VerticalOptions="Center"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#4b5563, Dark=#94a3b8}" />
                        </HorizontalStackLayout>
                        
                        <Label Grid.Column="1"
                               Text="Şifremi unuttum"
                               TextColor="{StaticResource PrimaryColor}"
                               FontSize="14"
                               FontAttributes="Bold"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- Login Button -->
                    <Button Text="Giriş Yap"
                            Command="{Binding LoginCommand}"
                            BackgroundColor="{AppThemeBinding Light=#111827, Dark=#3b82f6}"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="52"
                            CornerRadius="14"
                            Margin="0,5,0,0"/>

                    <!-- Divider -->
                    <Grid ColumnDefinitions="*,Auto,*" Margin="0,10">
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderLightColor}, Dark=#334155}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Veya şununla giriş yap" FontSize="12" TextColor="#9ca3af" Margin="12,0" VerticalOptions="Center"/>
                        <BoxView Grid.Column="2" HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderLightColor}, Dark=#334155}" VerticalOptions="Center" />
                    </Grid>

                    <!-- Social Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <!-- Google -->
                        <Button Grid.Column="0"
                                Text=" Google"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#0f172a}"
                                TextColor="{AppThemeBinding Light=#374151, Dark=#cbd5e1}"
                                BorderColor="{AppThemeBinding Light={StaticResource BorderLightColor}, Dark=#334155}"
                                BorderWidth="1"
                                CornerRadius="14"
                                HeightRequest="52"
                                FontSize="14"
                                FontAttributes="Bold" />
                        <!-- Apple -->
                        <Button Grid.Column="1"
                                Text=" Apple"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#0f172a}"
                                TextColor="{AppThemeBinding Light=#374151, Dark=#cbd5e1}"
                                BorderColor="{AppThemeBinding Light={StaticResource BorderLightColor}, Dark=#334155}"
                                BorderWidth="1"
                                CornerRadius="14"
                                HeightRequest="52"
                                FontSize="14"
                                FontAttributes="Bold" />
                    </Grid>

                    <!-- Register Link -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                        <Label Text="Hesabınız yok mu?" 
                               TextColor="{AppThemeBinding Light=#4b5563, Dark=#94a3b8}"
                               FontSize="14" 
                               VerticalOptions="Center"/>
                        <Button Text="Kayıt Ol" 
                                Command="{Binding NavigateToRegisterCommand}"
                                TextColor="{StaticResource PrimaryColor}"
                                BackgroundColor="Transparent"
                                FontSize="14"
                                FontAttributes="Bold"
                                Padding="0"
                                Margin="0"
                                HeightRequest="30"
                                VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>