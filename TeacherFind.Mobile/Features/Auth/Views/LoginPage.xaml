<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherFind.Mobile.Features.Auth.ViewModels"
             x:Class="TeacherFind.Mobile.Features.Auth.Views.LoginPage"
             BackgroundColor="#F3F4F6"
             x:DataType="vm:LoginViewModel">

    <ScrollView>
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="400" Padding="24">
            <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="32" StrokeThickness="0">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Hoş Geldiniz" FontSize="24" FontAttributes="Bold" TextColor="#111827" HorizontalOptions="Center"/>
                    <Label Text="Devam etmek için giriş yapın" FontSize="14" TextColor="#6B7280" HorizontalOptions="Center" Margin="0,-10,0,10"/>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="E-posta" TextColor="#374151" FontAttributes="Bold" FontSize="14"/>
                        <Border StrokeShape="RoundRectangle 8" Stroke="#D1D5DB" StrokeThickness="1" Padding="12,2">
                            <Entry Text="{Binding Email}" Placeholder="E-posta adresinizi girin" Keyboard="Email" BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Şifre" TextColor="#374151" FontAttributes="Bold" FontSize="14"/>
                        <Border StrokeShape="RoundRectangle 8" Stroke="#D1D5DB" StrokeThickness="1" Padding="12,2">
                            <Entry Text="{Binding Password}" IsPassword="True" Placeholder="Şifrenizi girin" BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="Giriş Yap" BackgroundColor="#111827" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="48" Command="{Binding LoginCommand}"/>

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>