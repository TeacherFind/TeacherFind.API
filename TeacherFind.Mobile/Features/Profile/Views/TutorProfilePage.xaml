<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:TeacherFind.Mobile.Shared.Components"
             x:Class="TeacherFind.Mobile.Features.Profile.Views.TutorProfilePage"
             Title="Öğretmen Profili"
             BackgroundColor="{AppThemeBinding Light=#f1f5f9, Dark=#0f172a}"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <ScrollView Padding="20,40,20,100">
            <VerticalStackLayout Spacing="24">

                <!-- Header -->
                <VerticalStackLayout Spacing="5" Margin="0,0,0,10">
                    <Label Text="Profil Yönetimi" 
                           FontSize="28" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}"/>
                    <Label Text="Kişisel bilgilerinizi ve uzmanlık detaylarınızı güncelleyin." 
                           FontSize="14" 
                           TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                </VerticalStackLayout>

                <!-- Avatar Section -->
                <Border Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#334155}" 
                        StrokeThickness="1" 
                        BackgroundColor="{AppThemeBinding Light=#ffffff, Dark=#1e293b}"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#e2e8f0, Dark=#000000}" Offset="0,10" Radius="20" Opacity="0.1" />
                    </Border.Shadow>

                    <VerticalStackLayout HorizontalOptions="Center" Spacing="15">
                        <Grid WidthRequest="120" HeightRequest="120">
                            <Border Stroke="{AppThemeBinding Light=#f1f5f9, Dark=#334155}" StrokeThickness="4" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="60" />
                                </Border.StrokeShape>
                                <!-- Profile Image -->
                                <Image Source="{Binding ProfileImageUrl}" Aspect="AspectFill" />
                            </Border>
                            
                            <!-- Camera Button -->
                            <Border WidthRequest="36" HeightRequest="36" 
                                    BackgroundColor="#2d79f3" 
                                    Stroke="White" StrokeThickness="2"
                                    HorizontalOptions="End" VerticalOptions="End" Margin="0,0,5,5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Label Text="📷" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding UploadAvatarCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>

                        <Label Text="{Binding FullName}" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}"/>
                        <Label Text="DOĞRULANMIŞ EĞİTMEN" FontSize="12" FontAttributes="Bold" TextColor="#2d79f3" HorizontalOptions="Center" CharacterSpacing="1"/>
                    </VerticalStackLayout>
                </Border>

                <!-- General Info Form -->
                <Border Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#334155}" 
                        StrokeThickness="1" 
                        BackgroundColor="{AppThemeBinding Light=#ffffff, Dark=#1e293b}"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Genel Bilgiler" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}" Margin="0,0,0,10"/>
                        
                        <!-- Full Name -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="TAM ADINIZ" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Entry Text="{Binding FullName}" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}" />
                        </VerticalStackLayout>

                        <!-- Email (Read-only) -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="E-POSTA ADRESİ" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Entry Text="{Binding Email}" IsReadOnly="True" BackgroundColor="{AppThemeBinding Light=#f1f5f9, Dark=#1e293b}" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#64748b}" />
                        </VerticalStackLayout>

                        <!-- Phone -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="TELEFON NUMARASI" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Entry Text="{Binding Phone}" Keyboard="Telephone" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}" />
                        </VerticalStackLayout>

                        <!-- Headline -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="PROFİL BAŞLIĞI" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Entry Text="{Binding Headline}" Placeholder="Örn: Deneyimli Matematik Öğretmeni" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}" />
                        </VerticalStackLayout>

                        <!-- University -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="ÜNİVERSİTE" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Picker ItemsSource="{Binding Universities}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedUniversity}" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}"/>
                        </VerticalStackLayout>

                        <!-- Department -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="BÖLÜM" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Picker ItemsSource="{Binding Departments}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedDepartment}" IsEnabled="{Binding IsDepartmentEnabled}" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- About & Expertise Form -->
                <Border Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#334155}" 
                        StrokeThickness="1" 
                        BackgroundColor="{AppThemeBinding Light=#ffffff, Dark=#1e293b}"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Hakkımda &amp; Uzmanlık" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}" Margin="0,0,0,10"/>

                        <!-- Bio -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="BİYOGRAFİ" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Editor Text="{Binding Bio}" HeightRequest="120" AutoSize="TextChanges" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}"/>
                        </VerticalStackLayout>

                        <!-- Teaching Style -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="EĞİTİM METODU / STİL" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Editor Text="{Binding TeachingStyle}" HeightRequest="100" AutoSize="TextChanges" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}"/>
                        </VerticalStackLayout>

                        <!-- Experience -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="DENEYİM" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Editor Text="{Binding Experience}" HeightRequest="100" AutoSize="TextChanges" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Save Button -->
                <Button Text="Bilgileri Kaydet" 
                        Command="{Binding SaveCommand}"
                        BackgroundColor="#2d79f3" 
                        TextColor="White" 
                        CornerRadius="24" 
                        HeightRequest="54" 
                        FontAttributes="Bold" 
                        FontSize="16"
                        Margin="0,10,0,30">
                    <Button.Shadow>
                        <Shadow Brush="#2d79f3" Offset="0,4" Radius="10" Opacity="0.4" />
                    </Button.Shadow>
                </Button>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Floating Bottom Bar -->
        <components:BottomNavBar />
        
        <!-- Loading Overlay -->
        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="#80000000">
            <ActivityIndicator IsRunning="True" Color="#2d79f3" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>
    </Grid>
</ContentPage>
