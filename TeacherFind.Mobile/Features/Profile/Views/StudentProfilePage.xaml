<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:TeacherFind.Mobile.Shared.Components"
             x:Class="TeacherFind.Mobile.Features.Profile.Views.StudentProfilePage"
             Title="Öğrenci Profili"
             BackgroundColor="{AppThemeBinding Light=#f1f5f9, Dark=#0f172a}"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <ScrollView Padding="20,40,20,100">
            <VerticalStackLayout Spacing="24">

                <!-- Header -->
                <VerticalStackLayout Spacing="5" Margin="0,0,0,10">
                    <Label Text="Profil Yönetimi" 
                           FontSize="28" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}"/>
                    <Label Text="Kişisel bilgilerinizi buradan güncelleyebilirsiniz." 
                           FontSize="14" 
                           TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                </VerticalStackLayout>

                <!-- Avatar Section -->
                <Border Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#334155}" 
                        StrokeThickness="1" 
                        BackgroundColor="{AppThemeBinding Light=#ffffff, Dark=#1e293b}"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#e2e8f0, Dark=#000000}" Offset="0,10" Radius="20" Opacity="0.1" />
                    </Border.Shadow>

                    <VerticalStackLayout HorizontalOptions="Center" Spacing="15">
                        <Grid WidthRequest="120" HeightRequest="120">
                            <Border Stroke="{AppThemeBinding Light=#f1f5f9, Dark=#334155}" StrokeThickness="4" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="60" />
                                </Border.StrokeShape>
                                <Image Source="{Binding ProfileImageUrl}" Aspect="AspectFill" />
                            </Border>
                            
                            <Border WidthRequest="36" HeightRequest="36" 
                                    BackgroundColor="#2d79f3" 
                                    Stroke="White" StrokeThickness="2"
                                    HorizontalOptions="End" VerticalOptions="End" Margin="0,0,5,5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Label Text="📷" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding UploadAvatarCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>

                        <Label Text="{Binding FullName}" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}"/>
                        <Label Text="ÖĞRENCİ" FontSize="12" FontAttributes="Bold" TextColor="#2d79f3" HorizontalOptions="Center" CharacterSpacing="1"/>
                    </VerticalStackLayout>
                </Border>

                <!-- General Info Form -->
                <Border Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#334155}" 
                        StrokeThickness="1" 
                        BackgroundColor="{AppThemeBinding Light=#ffffff, Dark=#1e293b}"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Genel Bilgiler" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}" Margin="0,0,0,10"/>
                        
                        <!-- Full Name -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="TAM ADINIZ" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Entry Text="{Binding FullName}" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}" />
                        </VerticalStackLayout>

                        <!-- Email (Read-only) -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="E-POSTA ADRESİ" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                <Entry Grid.Column="0" Text="{Binding Email}" IsReadOnly="True" BackgroundColor="{AppThemeBinding Light=#f1f5f9, Dark=#1e293b}" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#64748b}" />
                                <Button Grid.Column="1"
                                        Text="Değiştir"
                                        Command="{Binding OpenEmailChangeCommand}"
                                        BackgroundColor="Transparent"
                                        BorderColor="#2d79f3"
                                        BorderWidth="1"
                                        TextColor="#2d79f3"
                                        CornerRadius="12"
                                        HeightRequest="44"/>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Phone -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="TELEFON NUMARASI" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Entry Text="{Binding Phone}" Keyboard="Telephone" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}" />
                        </VerticalStackLayout>

                        <!-- Bio -->
                        <VerticalStackLayout Spacing="5" Margin="0,10,0,0">
                            <Label Text="KENDİNİZDEN KISACA BAHSEDİN" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                            <Editor Text="{Binding Bio}" HeightRequest="120" AutoSize="TextChanges" BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0f172a}" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Save Button -->
                <Button Text="Bilgileri Kaydet" 
                        Command="{Binding SaveCommand}"
                        BackgroundColor="#2d79f3" 
                        TextColor="White" 
                        CornerRadius="24" 
                        HeightRequest="54" 
                        FontAttributes="Bold" 
                        FontSize="16"
                        Margin="0,10,0,30">
                    <Button.Shadow>
                        <Shadow Brush="#2d79f3" Offset="0,4" Radius="10" Opacity="0.4" />
                    </Button.Shadow>
                </Button>

            </VerticalStackLayout>
        </ScrollView>

        <components:BottomNavBar />

        <Grid IsVisible="{Binding IsEmailChangeModalVisible}" BackgroundColor="#99000000" Padding="20">
            <Border VerticalOptions="Center"
                    Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#334155}"
                    BackgroundColor="{AppThemeBinding Light=#ffffff, Dark=#1e293b}"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="E-posta Değiştir" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#ffffff}" />
                        <Button Grid.Column="1"
                                Text="✕"
                                Command="{Binding CloseEmailChangeCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light=#64748b, Dark=#cbd5e1}"
                                WidthRequest="42"
                                HeightRequest="42"/>
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding IsEmailChangeRequestStepVisible}" Spacing="10">
                        <Label Text="Yeni e-posta adresinizi girin. Doğrulama kodu bu adrese gönderilecek."
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}" />
                        <Entry Text="{Binding NewEmail}" Keyboard="Email" Placeholder="yeni-email@example.com" />
                        <Button Text="Kod Gönder"
                                Command="{Binding SendEmailChangeCodeCommand}"
                                BackgroundColor="#2d79f3"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="50"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding IsEmailChangeCodeStepVisible}" Spacing="10">
                        <Label Text="{Binding NewEmail}" FontSize="13" FontAttributes="Bold" TextColor="#2d79f3" />
                        <Entry Text="{Binding EmailChangeCode}" Keyboard="Numeric" Placeholder="6 haneli kod" MaxLength="6" />
                        <Button Text="E-postayı Değiştir"
                                Command="{Binding VerifyEmailChangeCommand}"
                                BackgroundColor="#2d79f3"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="50"/>
                    </VerticalStackLayout>

                    <Label Text="{Binding EmailChangeMessage}"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#ef4444, Dark=#fca5a5}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>
        </Grid>
        
        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="#80000000">
            <ActivityIndicator IsRunning="True" Color="#2d79f3" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>
    </Grid>
</ContentPage>
