<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeacherFind.Mobile.Features.Search.Views.SearchFilterPage"
             Title="Filtreler"
             BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,10,0,20">
            <Label Grid.Column="0" Text="Filtreler" FontSize="22" FontAttributes="Bold" TextColor="#0A194F" VerticalOptions="Center"/>
            <Button Grid.Column="1" Text="✕" FontSize="18" TextColor="Gray" BackgroundColor="Transparent" Clicked="OnCloseButtonClicked"/>
        </Grid>

        <ScrollView Grid.Row="1" Margin="0,0,0,20">
            <VerticalStackLayout Spacing="20">

                <VerticalStackLayout Spacing="5">
                    <Label Text="🔍 ARAMA" FontSize="11" FontAttributes="Bold" TextColor="Gray"/>
                    <Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" BackgroundColor="White" Padding="10,0">
                        <Entry Text="{Binding SearchText}" Placeholder="İsim veya konu..." PlaceholderColor="LightGray" HeightRequest="45"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="🗂 KATEGORİ" FontSize="11" FontAttributes="Bold" TextColor="Gray"/>
                    <Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" BackgroundColor="White" Padding="10,0">
                        <Picker Title="Kategori Seçin" TextColor="#212121" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" HeightRequest="45"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="📍 KONUM" FontSize="11" FontAttributes="Bold" TextColor="Gray"/>
                    <Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" BackgroundColor="White" Padding="10,0">
                        <Picker Title="Konum Seçin" TextColor="#212121" ItemsSource="{Binding Locations}" SelectedItem="{Binding SelectedLocation}" HeightRequest="45"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="💻 DERS TİPİ" FontSize="11" FontAttributes="Bold" TextColor="Gray"/>
                    <Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" BackgroundColor="White" Padding="10,0">
                        <Picker Title="Ders Tipi Seçin" TextColor="#212121" ItemsSource="{Binding LessonTypes}" SelectedItem="{Binding SelectedLessonType}" HeightRequest="45"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="💰 FİYAT ARALIĞI" FontSize="11" FontAttributes="Bold" TextColor="Gray"/>
                    <Grid ColumnDefinitions="*, 15, *">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" BackgroundColor="White" Padding="10,0">
                            <Entry Text="{Binding MinPrice}" Placeholder="Min" Keyboard="Numeric" PlaceholderColor="LightGray" HeightRequest="45" HorizontalTextAlignment="Center"/>
                        </Border>
                        <Label Grid.Column="1" Text="-" VerticalOptions="Center" HorizontalOptions="Center" TextColor="Gray"/>
                        <Border Grid.Column="2" StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" BackgroundColor="White" Padding="10,0">
                            <Entry Text="{Binding MaxPrice}" Placeholder="Max" Keyboard="Numeric" PlaceholderColor="LightGray" HeightRequest="45" HorizontalTextAlignment="Center"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="2" Text="Filtreleri Uygula" Command="{Binding ApplyFiltersCommand}" BackgroundColor="#2962FF" TextColor="White" FontAttributes="Bold" CornerRadius="12" HeightRequest="50"/>
    </Grid>
</ContentPage>