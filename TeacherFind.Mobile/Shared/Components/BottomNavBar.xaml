<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeacherFind.Mobile.Shared.Components.BottomNavBar">
    
    <!-- Floating Bottom Bar (Pill Shape) -->
    <Border Stroke="{AppThemeBinding Light=#e5e7eb, Dark=#334155}"
            StrokeThickness="1"
            BackgroundColor="{AppThemeBinding Light=#ffffff, Dark=#0f172a}"
            Margin="10,0,10,8"
            Padding="15,5"
            HorizontalOptions="Fill"
            VerticalOptions="End">
        <Border.Shadow>
            <Shadow Brush="{AppThemeBinding Light=#cbd5e1, Dark=#000000}" Offset="0,5" Radius="15" Opacity="0.2" />
        </Border.Shadow>
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="28" />
        </Border.StrokeShape>

        <Grid ColumnDefinitions="*, *, Auto, *, *" ColumnSpacing="10" VerticalOptions="Center">
            
            <!-- 1. Ana Sayfa (Home) -->
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center" Padding="0,5">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <!-- Home Icon SVG -->
                <Path Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" 
                      Fill="{AppThemeBinding Light=#64748b, Dark=#94a3b8}" 
                      Aspect="Uniform" HeightRequest="22" WidthRequest="22"/>
            </VerticalStackLayout>

            <!-- 2. Mesajlar (Messages) -->
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Center" Padding="0,5">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <!-- Message Icon SVG -->
                <Path Data="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z" 
                      Fill="{AppThemeBinding Light=#64748b, Dark=#94a3b8}" 
                      Aspect="Uniform" HeightRequest="22" WidthRequest="22"/>
            </VerticalStackLayout>

            <!-- 3. Eğitmen Keşfet (Orta Büyük Buton) -->
            <Border Grid.Column="2" 
                    BackgroundColor="{AppThemeBinding Light=#111827, Dark=#3b82f6}" 
                    Stroke="Transparent"
                    HeightRequest="48" WidthRequest="48"
                    VerticalOptions="Center" HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#111827, Dark=#3b82f6}" Offset="0,3" Radius="8" Opacity="0.3" />
                </Border.Shadow>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSearchTapped" />
                </Border.GestureRecognizers>
                
                <!-- Search/Discover Icon SVG (White) -->
                <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                      Fill="White" 
                      Aspect="Uniform" HeightRequest="24" WidthRequest="24"
                      HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- 4. Derslerim/Favoriler -->
            <VerticalStackLayout Grid.Column="3" VerticalOptions="Center" HorizontalOptions="Center" Padding="0,5">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFavoritesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <!-- Bookmark/Favorite Icon SVG -->
                <Path Data="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2z" 
                      Fill="{AppThemeBinding Light=#64748b, Dark=#94a3b8}" 
                      Aspect="Uniform" HeightRequest="22" WidthRequest="22"/>
            </VerticalStackLayout>

            <!-- 5. Profil -->
            <VerticalStackLayout Grid.Column="4" VerticalOptions="Center" HorizontalOptions="Center" Padding="0,5">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnProfileTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <!-- Profile/User Icon SVG -->
                <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" 
                      Fill="{AppThemeBinding Light=#64748b, Dark=#94a3b8}" 
                      Aspect="Uniform" HeightRequest="22" WidthRequest="22"/>
            </VerticalStackLayout>
            
        </Grid>
    </Border>

</ContentView>
