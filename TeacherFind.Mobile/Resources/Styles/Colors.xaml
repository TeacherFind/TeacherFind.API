<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Global Colors -->
    <Color x:Key="PrimaryColor">#2d79f3</Color>
    <Color x:Key="PrimaryDarkColor">#1e40af</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#111827</Color>
    <Color x:Key="TextSecondaryColor">#6b7280</Color>
    <Color x:Key="TextWhiteColor">#ffffff</Color>

    <!-- Background Colors -->
    <Color x:Key="BgLightColor">#f9fafb</Color>
    <Color x:Key="BgCardLightColor">#ffffff</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderLightColor">#e5e7eb</Color>

    <!-- AppThemeBinding for Dark Mode Support -->
    <Color x:Key="PageBackgroundColorLight">#f1f5f9</Color>
    <Color x:Key="PageBackgroundColorDark">#0f172a</Color>

</ResourceDictionary>
